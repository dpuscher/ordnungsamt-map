# PostgreSQL
POSTGIS_PLATFORM=linux/amd64
POSTGIS_IMAGE=postgis/postgis:18-3.6
TZ=Europe/Berlin
POSTGRES_DB=ordnungsamt
POSTGRES_USER=ordnungsamt
POSTGRES_PASSWORD=change_me_in_production

# Connection URLs (used by backend & collector)
DATABASE_URL=postgresql://ordnungsamt:change_me_in_production@postgres:5432/ordnungsamt
REDIS_URL=redis://redis:6379

# Backend
CORS_ORIGIN=https://your-frontend-domain.com
BACKEND_PORT=4000

# Frontend
FRONTEND_PORT=3000
VITE_API_URL=https://your-api-domain.com

# Collector
COLLECTOR_INTERVAL_MINUTES=15
OA_BULK_FETCH_TIMEOUT_MS=600000
OA_DETAIL_FETCH_TIMEOUT_MS=15000
